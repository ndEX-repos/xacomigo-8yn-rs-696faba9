---
import { loadSiteData } from "../lib/load-site-data";

const site = loadSiteData();
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <title>{site.title}</title>
    <link href={site.faviconHref ?? "/favicon.ico"} rel="icon" type={site.faviconContentType ?? "image/x-icon"} />
  </head>
  <body>
    <main>
      <h1>{site.h1 ?? site.title}</h1>
    </main>
  </body>
</html>
